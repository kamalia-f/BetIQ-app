  const FP = ["Home Win","Away Win","Draw","Both Teams Score","Over 2.5 Goals","Under 2.5 Goals","Home Win & Over 2.5","Away Win & BTTS","Double Chance Home/Draw","First Half Over 1.5"];
  const BP = ["Home Win","Away Win","Over 215.5","Under 215.5","Home -4.5","Away +4.5","First Half Over","Double Chance","Over 230.5","Away -3.5"];

  useEffect(() => { fetchSavedSlips(); }, [user]);

